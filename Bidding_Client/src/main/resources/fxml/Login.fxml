<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.auth.LoginController">
    <children>
        <VBox prefHeight="720.0" prefWidth="550.0" style="-fx-background-color: linear-gradient(to bottom right, #0F172A, #1E293B); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 5, 0, 0);">
            <children>
                <ImageView fitHeight="720.0" fitWidth="550.0" pickOnBounds="true" preserveRatio="false">
                    <image>
                        <Image url="@../images/GavelImg.png" />
                    </image>
                </ImageView>
            </children>
        </VBox>

        <StackPane style="-fx-background-color: #E8EEF2;" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" prefWidth="480.0" spacing="22.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.1), 40, 0, 0, 15);">
                    <padding>
                        <Insets bottom="50.0" left="45.0" right="45.0" top="50.0" />
                    </padding>
                    <children>
                        
                        <VBox alignment="CENTER" spacing="5.0">
                            <Label text="WELCOME BACK" textFill="#0F172A">
                                <font>
                                    <Font name="System Bold" size="32.0" />
                                </font>
                                <style>
                                    -fx-letter-spacing: 1px;
                                </style>
                            </Label>
                            <Label text="Sign in to your account to continue" textFill="#64748B">
                                <font>
                                    <Font size="14.0" />
                                </font>
                                <VBox.margin>
                                    <Insets bottom="10.0" />
                                </VBox.margin>
                            </Label>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label fx:id="lblMessage" textFill="#DC2626">
                                <font>
                                    <Font name="System Bold" size="13.0" />
                                </font>
                            </Label>
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Username" textFill="#475569">
                                <font>
                                    <Font name="System Bold" size="13.0" />
                                </font>
                            </Label>
                            <TextField fx:id="txtUsername" prefHeight="50.0" promptText="Enter your username" style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-border-color: #CBD5E1; -fx-border-radius: 12; -fx-padding: 0 15; -fx-font-size: 15px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" />
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Password" textFill="#475569">
                                <font>
                                    <Font name="System Bold" size="13.0" />
                                </font>
                            </Label>
                            <StackPane alignment="CENTER_RIGHT">
                                <children>
                                    <TextField fx:id="txtPasswordVisible" managed="false" prefHeight="50.0" promptText="Enter your password" style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-border-color: #CBD5E1; -fx-border-radius: 12; -fx-padding: 0 45 0 15; -fx-font-size: 15px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" visible="false" />
                                    
                                    <PasswordField fx:id="txtPassword" prefHeight="50.0" promptText="Enter your password" style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-border-color: #CBD5E1; -fx-border-radius: 12; -fx-padding: 0 45 0 15; -fx-font-size: 15px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" />
                                    
                                    <ImageView fx:id="iconEye" fitHeight="22.0" fitWidth="22.0" onMouseClicked="#togglePasswordVisibility" pickOnBounds="true" preserveRatio="true" style="-fx-cursor: hand;">
                                        <StackPane.margin>
                                            <Insets right="15.0" />
                                        </StackPane.margin>
                                    </ImageView>
                                </children>
                            </StackPane>
                        </VBox>

                        <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" onAction="#handleLogin" prefHeight="55.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FDE047); -fx-background-radius: 12; -fx-text-fill: #451A03; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 18, 0, 0, 6);" text="SIGN IN">
                            <font>
                                <Font name="System ExtraBold" size="16.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                        </Button>

                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Don't have an account?" textFill="#64748B">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                                <Button fx:id="btnGoToRegister" onAction="#switchRegister" style="-fx-background-color: transparent; -fx-text-fill: #B8860B; -fx-cursor: hand; -fx-underline: true;" text="Register now">
                                    <font>
                                        <Font name="System Bold" size="15.0" />
                                    </font>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </VBox>
                        
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</HBox>