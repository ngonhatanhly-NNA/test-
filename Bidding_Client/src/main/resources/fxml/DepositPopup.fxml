<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="550.0" spacing="25.0" style="-fx-background-color: #121212; -fx-padding: 35;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.DepositController">

    <VBox alignment="CENTER" spacing="5.0">
        <HBox alignment="CENTER" spacing="12.0">
            <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@../images/shopkeeper.png" /></image>
                <style>-fx-effect: dropshadow(gaussian, rgba(212,175,55,0.5), 10, 0, 0, 0);</style>
            </ImageView>
            <Label text="NẠP TIỀN VÀO VÍ" textFill="#D4AF37">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
                <style>
                    -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 10, 0, 0, 0);
                    -fx-letter-spacing: 1.5px;
                </style>
            </Label>
            <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@../images/shopkeeper.png" /></image>
                <style>-fx-effect: dropshadow(gaussian, rgba(212,175,55,0.5), 10, 0, 0, 0);</style>
            </ImageView>
        </HBox>
        <Label text="Nạp tiền để có thể tham gia các phiên đấu giá" textFill="#A0A0A0">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
        </Label>
    </VBox>

    <VBox maxWidth="450.0" spacing="20.0" style="-fx-background-color: #181818; -fx-background-radius: 20; -fx-border-color: rgba(212,175,55,0.3); -fx-border-radius: 20; -fx-border-width: 1.5; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 20, 0, 0, 8);">

        <VBox alignment="CENTER" spacing="8.0" style="-fx-background-color: #242424; -fx-border-color: rgba(52,211,153,0.3); -fx-border-width: 1.5; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 3);">
            <Label text="Số dư ví hiện tại:" textFill="#E0E0E0">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <Label fx:id="lblCurrentBalance" text="0 VNĐ" textFill="#34D399">
                <font><Font name="System Bold" size="24.0" /></font>
                <style>-fx-effect: dropshadow(gaussian, rgba(52,211,153,0.4), 10, 0, 0, 0);</style>
            </Label>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Hình thức thanh toán:" textFill="#E0E0E0">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <ComboBox fx:id="cmbPaymentMethod" maxWidth="Infinity" prefHeight="45.0" promptText="Chọn hình thức thanh toán..." style="-fx-background-color: #242424; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #F5F5F5; -fx-padding: 0 10; -fx-cursor: hand;" />
        </VBox>

        <VBox spacing="8.0">
            <Label text="Số tiền nạp (VNĐ):" textFill="#E0E0E0">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <TextField fx:id="txtDepositAmount" prefHeight="45.0" promptText="VD: 100000" style="-fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #F8FAFC; -fx-prompt-text-fill: #64748B; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.6), 5, 0, 0, 2);" />
            <Label fx:id="lblAmountError" text="" textFill="#EF4444">
                <font><Font name="System Italic" size="12.0" /></font>
            </Label>
        </VBox>

        <VBox spacing="10.0">
            <Label text="Mức nạp nhanh:" textFill="#A0A0A0">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <HBox alignment="CENTER" spacing="12.0">
                <Button onAction="#handleQuickDeposit100k" prefHeight="38.0" prefWidth="85.0" style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="100K" />
                <Button onAction="#handleQuickDeposit500k" prefHeight="38.0" prefWidth="85.0" style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="500K" />
                <Button onAction="#handleQuickDeposit1m" prefHeight="38.0" prefWidth="85.0" style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="1M" />
                <Button onAction="#handleQuickDeposit5m" prefHeight="38.0" prefWidth="85.0" style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="5M" />
            </HBox>
        </VBox>

        <VBox spacing="8.0" style="-fx-background-color: #242424; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15;">
            <Label text="Người nhận (Tên cửa hàng):" textFill="#A0A0A0">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <TextField fx:id="txtRecipient" disable="true" prefHeight="38.0" style="-fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 6; -fx-padding: 0 12; -fx-text-fill: #94A3B8;" />
            
            <Label style="-fx-padding: 5 0 0 0;" text="Số tài khoản (TK):" textFill="#A0A0A0">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <TextField fx:id="txtAccountNumber" disable="true" prefHeight="38.0" style="-fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 6; -fx-padding: 0 12; -fx-text-fill: #94A3B8;" />
        </VBox>

        <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="btnDeposit" onAction="#handleDeposit" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 15, 0, 0, 0);" text="TIẾN HÀNH NẠP TIỀN" />

            <ProgressIndicator fx:id="progressIndicator" prefHeight="35.0" prefWidth="35.0" visible="false" />

            <Label fx:id="lblStatus" text="" textFill="#10B981">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
        </VBox>

    </VBox>

    <VBox maxWidth="450.0" spacing="6.0" style="-fx-background-color: rgba(245,158,11,0.1); -fx-border-color: rgba(245,158,11,0.3); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15;">
        <Label text="⚠️ HƯỚNG DẪN:" textFill="#F59E0B">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <Label text="• Nhập số tiền muốn nạp (tối thiểu: 10.000 VNĐ)" textFill="#D4AF37" wrapText="true">
            <font><Font size="12.0" /></font>
        </Label>
        <Label text="• Chọn hình thức thanh toán" textFill="#D4AF37" wrapText="true">
            <font><Font size="12.0" /></font>
        </Label>
        <Label text="• Xác nhận và chờ hệ thống xử lý giao dịch" textFill="#D4AF37" wrapText="true">
            <font><Font size="12.0" /></font>
        </Label>
    </VBox>

</VBox>
