<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="520.0" spacing="22.0" style="-fx-background-color: #FFFFFF; -fx-padding: 40; -fx-border-radius: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.15), 35, 0, 0, 10);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.CreateItemController">
    <children>

        <VBox spacing="4.0">
            <Label text="Create Auction Item" textFill="#0F172A">
                <font><Font name="System Bold" size="28.0" /></font>
                <style>-fx-letter-spacing: 0.5px;</style>
            </Label>
            <Label text="List a new asset for bidding on the marketplace." textFill="#64748B">
                <font><Font size="14.0" /></font>
            </Label>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Item Name" textFill="#475569">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <TextField fx:id="txtItemName" prefHeight="48.0" promptText="Enter item name..." style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" />
        </VBox>

        <VBox spacing="8.0">
            <Label text="Category" textFill="#475569">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <ComboBox fx:id="cbCategory" prefHeight="48.0" prefWidth="500.0" promptText="Select category" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" />
        </VBox>

        <VBox fx:id="vboxElectronics" spacing="10.0" managed="false" visible="false">
            <HBox spacing="10.0">
                <TextField fx:id="txtElecBrand" prefHeight="45.0" HBox.hgrow="ALWAYS" promptText="Brand" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
                <TextField fx:id="txtElecModel" prefHeight="45.0" HBox.hgrow="ALWAYS" promptText="Model" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
            </HBox>
            <TextField fx:id="txtElecWarranty" prefHeight="45.0" promptText="Warranty period (in months)" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
        </VBox>

        <VBox fx:id="vboxVehicle" spacing="10.0" managed="false" visible="false">
            <HBox spacing="10.0">
                <TextField fx:id="txtVehYear" prefHeight="45.0" HBox.hgrow="ALWAYS" promptText="Manufacturing year" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
                <TextField fx:id="txtVehMileage" prefHeight="45.0" HBox.hgrow="ALWAYS" promptText="Mileage" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
            </HBox>
            <TextField fx:id="txtVehVin" prefHeight="45.0" promptText="VIN Number" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
        </VBox>

        <VBox fx:id="vboxArt" spacing="10.0" managed="false" visible="false">
            <HBox spacing="10.0">
                <TextField fx:id="txtArtArtist" prefHeight="45.0" HBox.hgrow="ALWAYS" promptText="Artist's name" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
                <ComboBox fx:id="cbArtCert" prefHeight="45.0" HBox.hgrow="ALWAYS" promptText="Is it authentic?" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;"/>
            </HBox>
            <TextField fx:id="txtArtMaterial" prefHeight="45.0" promptText="Art material" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-padding: 0 10;"/>
        </VBox>

        <!-- GỘP STARTING PRICE VÀ UPLOAD ẢNH VÀO CÙNG 1 HÀNG -->
        <HBox spacing="20.0" alignment="CENTER_LEFT">
            <children>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="Starting Price ($)" textFill="#475569">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="txtStartPrice" prefHeight="48.0" promptText="0.00" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-font-weight: bold; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" />
                </VBox>

                <!-- KHU VỰC THÊM ẢNH -->
                <VBox spacing="8.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label text="Item Image" textFill="#475569">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Button mnemonicParsing="false" onAction="#handleChooseImage" prefHeight="48.0" style="-fx-background-color: #E2E8F0; -fx-text-fill: #0F172A; -fx-background-radius: 10; -fx-cursor: hand;" text="Choose Image...">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <Label fx:id="lblImageName" text="No file selected" textFill="#94A3B8" />
                    </HBox>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="8.0">
            <Label text="Detailed Description" textFill="#475569">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <TextArea fx:id="txtDescription" prefHeight="100.0" promptText="Enter detailed product information..." style="-fx-control-inner-background: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 5; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <VBox.margin><Insets top="10.0" /></VBox.margin>
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="48.0" prefWidth="120.0" style="-fx-background-color: #FEF2F2; -fx-border-color: #F87171; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #DC2626; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.1), 5, 0, 0, 2);" text="Cancel">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#handleSaveItem" prefHeight="48.0" prefWidth="170.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FDE047); -fx-text-fill: #451A03; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 15, 0, 0, 5);" text="Publish Item">
                    <font><Font name="System ExtraBold" size="15.0" /></font>
                </Button>
            </children>
        </HBox>

    </children>
</VBox>