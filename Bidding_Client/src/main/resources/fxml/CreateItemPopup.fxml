<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="540.0" spacing="22.0" style="-fx-background-color: #181818; -fx-padding: 35 40; -fx-border-color: rgba(212,175,55,0.4); -fx-border-width: 2; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 30, 0, 0, 10);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.CreateItemController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <ImageView fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@../images/item119.png" /></image>
                <style>-fx-effect: dropshadow(gaussian, rgba(212,175,55,0.5), 8, 0, 0, 0);</style>
            </ImageView>
            <VBox spacing="2.0">
                <Label text="CREATE AUCTION ITEM" textFill="#D4AF37">
                    <font><Font name="System Bold" size="24.0" /></font>
                    <style>
                        -fx-letter-spacing: 1px;
                        -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 8, 0, 0, 0);
                    </style>
                </Label>
                <Label text="List a new pixel asset for bidding on the marketplace." textFill="#A0A0A0">
                    <font><Font name="System Italic" size="13.0" /></font>
                </Label>
            </VBox>
        </HBox>

        <VBox spacing="8.0">
            <Label text="Item Name" textFill="#E0E0E0">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <TextField fx:id="txtItemName" prefHeight="45.0" promptText="Enter item name..." style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 15; -fx-font-size: 14px; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.6), 5, 0, 0, 2);" />
        </VBox>

        <VBox spacing="8.0">
            <Label text="Category" textFill="#E0E0E0">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <ComboBox fx:id="cbCategory" maxWidth="Infinity" prefHeight="45.0" promptText="Select category" style="-fx-background-color: #242424; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-font-size: 14px; -fx-cursor: hand;" styleClass="dark-combo-box" />
        </VBox>

        <VBox fx:id="vboxElectronics" managed="false" spacing="10.0" visible="false">
            <HBox spacing="10.0">
                <TextField fx:id="txtElecBrand" prefHeight="42.0" promptText="Brand" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtElecModel" prefHeight="42.0" promptText="Model" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" HBox.hgrow="ALWAYS" />
            </HBox>
            <TextField fx:id="txtElecWarranty" prefHeight="42.0" promptText="Warranty period (in months)" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" />
        </VBox>

        <VBox fx:id="vboxVehicle" managed="false" spacing="10.0" visible="false">
            <HBox spacing="10.0">
                <TextField fx:id="txtVehYear" prefHeight="42.0" promptText="Manufacturing year" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtVehMileage" prefHeight="42.0" promptText="Mileage" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" HBox.hgrow="ALWAYS" />
            </HBox>
            <TextField fx:id="txtVehVin" prefHeight="42.0" promptText="VIN Number" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" />
        </VBox>

        <VBox fx:id="vboxArt" managed="false" spacing="10.0" visible="false">
            <HBox spacing="10.0">
                <TextField fx:id="txtArtArtist" prefHeight="42.0" promptText="Artist's name" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="cbArtCert" prefHeight="42.0" promptText="Is it authentic?" style="-fx-background-color: #242424; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-cursor: hand;" styleClass="dark-combo-box" HBox.hgrow="ALWAYS" />
            </HBox>
            <TextField fx:id="txtArtMaterial" prefHeight="42.0" promptText="Art material" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 0 10; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="Starting Price (VNĐ)" textFill="#E0E0E0">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="txtStartPrice" prefHeight="45.0" promptText="VD: 150000" style="-fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #34D399; -fx-prompt-text-fill: #64748B; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.6), 5, 0, 0, 2);" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="Item Image" textFill="#E0E0E0">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #242424; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 4;">
                        <Button mnemonicParsing="false" onAction="#handleChooseImage" prefHeight="35.0" style="-fx-background-color: #334155; -fx-text-fill: #F5F5F5; -fx-background-radius: 6; -fx-cursor: hand;" text="Choose Image...">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Button>
                        <Label fx:id="lblImageName" text="No file selected" textFill="#94A3B8">
                            <font><Font size="11.0" /></font>
                        </Label>
                    </HBox>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="8.0">
            <Label text="Detailed Description" textFill="#E0E0E0">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <TextArea fx:id="txtDescription" prefHeight="90.0" promptText="Enter detailed product information..." style="-fx-control-inner-background: rgba(0,0,0,0.3); -fx-background-color: transparent; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-padding: 5; -fx-font-size: 14px; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <VBox.margin><Insets top="10.0" /></VBox.margin>
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="45.0" prefWidth="110.0" style="-fx-background-color: transparent; -fx-border-color: rgba(239,68,68,0.6); -fx-border-width: 1.5; -fx-border-radius: 8; -fx-text-fill: #EF4444; -fx-cursor: hand;" text="Cancel">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#handleSaveItem" prefHeight="45.0" prefWidth="170.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 15, 0, 0, 0);" text="Publish Item">
                    <font><Font name="System ExtraBold" size="14.0" /></font>
                </Button>
            </children>
        </HBox>

    </children>
</VBox>
