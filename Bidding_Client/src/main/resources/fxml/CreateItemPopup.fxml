<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-border-radius: 10; -fx-background-radius: 10;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.CreateItemController">
    <children>
        <Label text="Thêm Sản Phẩm Đấu Giá" textFill="#1a1a1a">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <VBox spacing="5.0">
            <Label text="Tên sản phẩm" textFill="#666666" />
            <TextField fx:id="txtItemName" promptText="Nhập tên sản phẩm..." style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #ccc; -fx-border-radius: 5;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Loại hàng" textFill="#666666" />
            <ComboBox fx:id="cbCategory" prefWidth="400.0" promptText="Chọn danh mục" style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 5;" />
        </VBox>

        <HBox spacing="15.0">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Giá khởi điểm ($)" textFill="#666666" />
                    <TextField fx:id="txtStartPrice" promptText="0.00" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #ccc; -fx-border-radius: 5;" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Ngày kết thúc" textFill="#666666" />
                    <DatePicker fx:id="dpEndDate" prefWidth="200.0" style="-fx-border-color: #ccc; -fx-border-radius: 5;" />
                </VBox>
            </children>
        </HBox>

        <VBox spacing="5.0">
            <Label text="Mô tả chi tiết" textFill="#666666" />
            <TextArea fx:id="txtDescription" prefHeight="80.0" promptText="Nhập thông tin mô tả sản phẩm..." style="-fx-border-color: #ccc; -fx-border-radius: 5;" wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-border-color: #999; -fx-border-radius: 5; -fx-text-fill: #666; -fx-cursor: hand;" text="Hủy bỏ" />
                <Button mnemonicParsing="false" onAction="#handleSaveItem" style="-fx-background-color: #E3B04B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Đăng Sản Phẩm" />
            </children>
        </HBox>
    </children>
</VBox>