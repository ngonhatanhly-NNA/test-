<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #121212; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.client.controller.dashboard.TransferHistoryPopupController">

    <Label text="Lịch sử chuyển tiền" textFill="#D4AF37">
        <font><Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="tableTransferHistory" VBox.vgrow="ALWAYS"
               style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;">
        <columns>
            <TableColumn fx:id="colTransferBuyerName" prefWidth="150" text="Tên người mua" />
            <TableColumn fx:id="colTransferAmount" prefWidth="120" text="Số tiền" style="-fx-alignment: CENTER_RIGHT;" />
            <TableColumn fx:id="colTransferTime" prefWidth="180" text="Thời gian" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="colTransferItem" prefWidth="200" text="Sản phẩm đấu giá" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#handleRefresh" text="Tải lại"
                style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 15;">
            <font><Font name="System Bold" size="12.0" /></font>
        </Button>
        <Button onAction="#handleClose" text="Đóng"
                style="-fx-background-color: #242424; -fx-text-fill: #E0E0E0; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 15;">
            <font><Font name="System Bold" size="12.0" /></font>
        </Button>
    </HBox>

</VBox>