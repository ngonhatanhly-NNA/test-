<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-padding: 10 30 10 30;">
            <children>
                <Button onAction="#showApproveSellerDialog" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 12, 0, 0, 0); -fx-padding: 0 20;" text="✅ APPROVE SELLERS">
                    <font><Font name="System ExtraBold" size="13.0" /></font>
                </Button>
                <Button onAction="#refreshData" prefHeight="40.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #E0E0E0; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 20;" text="🔄 Refresh" />
            </children>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" style="-fx-background-color: transparent; -fx-tab-min-height: 40px; -fx-tab-min-width: 160px; -fx-font-weight: bold; -fx-font-size: 14px;" stylesheets="@tabstyle.css" tabClosingPolicy="UNAVAILABLE">
            
            <Tab text="Overview">
                <VBox spacing="25" style="-fx-padding: 30px; -fx-background-color: transparent;">
                    
                    <HBox spacing="25">
                        <VBox alignment="CENTER" style="-fx-background-color: #181818; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 25px; -fx-background-radius: 16; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #A0A0A0; -fx-font-weight: bold;" text="👥 TOTAL USERS" />
                            <Label fx:id="lblTotalUsers" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #3B82F6; -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.5), 15, 0, 0, 0);" text="0" />
                        </VBox>
                        
                        <VBox alignment="CENTER" style="-fx-background-color: #181818; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 25px; -fx-background-radius: 16; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #A0A0A0; -fx-font-weight: bold;" text="📦 TOTAL ITEMS" />
                            <Label fx:id="lblTotalProducts" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #10B981; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.5), 15, 0, 0, 0);" text="0" />
                        </VBox>
                        
                        <VBox alignment="CENTER" style="-fx-background-color: #181818; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 25px; -fx-background-radius: 16; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #A0A0A0; -fx-font-weight: bold;" text="🔨 AUCTIONS" />
                            <Label fx:id="lblTotalAuctions" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #EF4444; -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.5), 15, 0, 0, 0);" text="0" />
                        </VBox>
                        
                        <VBox alignment="CENTER" style="-fx-background-color: #181818; -fx-border-color: rgba(212,175,55,0.6); -fx-border-width: 1.5; -fx-padding: 25px; -fx-background-radius: 16; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.3), 25, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #D4AF37; -fx-font-weight: bold;" text="💰 TOTAL REVENUE (VNĐ)" />
                            <Label fx:id="lblRevenue" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.6), 15, 0, 0, 0);" text="0" />
                        </VBox>
                    </HBox>
                    
                    <VBox spacing="15" style="-fx-background-color: #181818; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 25px; -fx-background-radius: 16; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #F5F5F5;" text="System Activities" />
                        <ListView fx:id="listViewActivities" style="-fx-background-color: rgba(0,0,0,0.2); -fx-control-inner-background: rgba(0,0,0,0.2); -fx-border-color: rgba(212,175,55,0.1); -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </Tab>

            <Tab fx:id="userManagementTab" text="User Management">
                <VBox spacing="20" style="-fx-padding: 30px; -fx-background-color: transparent;">
                    <VBox spacing="20" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">
                        
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="System Accounts" HBox.hgrow="ALWAYS" />
                            
                            <Button onAction="#showAllUsers" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-cursor: hand;" text="Reload All Users">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Button>
                            
                            <TextField fx:id="txtSearchUsername" prefHeight="45.0" prefWidth="320.0" promptText="🔍 Search user by name..." style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B; -fx-background-radius: 10; -fx-border-color: rgba(212,175,55,0.3); -fx-border-radius: 10; -fx-font-size: 14px; -fx-padding: 0 15; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.8), 6, 0, 0, 2);" />
                            
                            <Button onAction="#handleSearchUser" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 0);" text="SEARCH">
                                <font><Font name="System ExtraBold" size="14.0" /></font>
                            </Button>
                        </HBox>

                        <TableView fx:id="tableUsers" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60" style="-fx-alignment: CENTER;" text="ID" />
                                <TableColumn fx:id="colUsername" prefWidth="150" text="Username" />
                                <TableColumn fx:id="colEmail" prefWidth="200" text="Email" />
                                <TableColumn fx:id="colRole" prefWidth="100" style="-fx-alignment: CENTER;" text="Role" />
                                <TableColumn fx:id="colStatus" prefWidth="120" style="-fx-alignment: CENTER;" text="Status" />
                                <TableColumn fx:id="colShopName" prefWidth="150" text="Shop Name" />
                                <TableColumn fx:id="colRating" prefWidth="80" style="-fx-alignment: CENTER;" text="Rating" />
                                <TableColumn fx:id="colVerified" prefWidth="120" style="-fx-alignment: CENTER;" text="Verified" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                    </VBox>
                </VBox>
            </Tab>

            <Tab fx:id="itemAnalysisTab" text="Item Analysis">
                <VBox spacing="20" style="-fx-padding: 30px; -fx-background-color: transparent;">
                    <VBox spacing="20" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">
                        
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="📊 Product Performance Analytics" HBox.hgrow="ALWAYS" />
                            <Button onAction="#loadProductAnalytics" prefHeight="45.0" style="-fx-background-color: rgba(16,185,129,0.2); -fx-text-fill: #34D399; -fx-border-color: #10B981; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 0 25;" text="GENERATE REPORT" />
                        </HBox>

                        <TableView fx:id="tableItems" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colItemId" prefWidth="80" style="-fx-alignment: CENTER;" text="ID" />
                                <TableColumn fx:id="colItemName" prefWidth="250" text="Name" />
                                <TableColumn fx:id="colItemDescription" prefWidth="300" text="Description" />
                                <TableColumn fx:id="colItemStartingPrice" prefWidth="150" style="-fx-alignment: CENTER_RIGHT;" text="Starting Price" />
                                <TableColumn fx:id="colItemStatus" prefWidth="120" style="-fx-alignment: CENTER;" text="Status" />
                                <TableColumn fx:id="colItemAction" prefWidth="150" style="-fx-alignment: CENTER;" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                    </VBox>
                </VBox>
            </Tab>

            <Tab fx:id="financialReportTab" text="Financial Report">
                <VBox spacing="20" style="-fx-padding: 30px; -fx-background-color: transparent;">
                    <VBox spacing="20" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(212,175,55,0.2); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">
                        
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D4AF37; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.2), 5, 0, 0, 0);" text="💰 System Revenue " HBox.hgrow="ALWAYS" />
                            <Button onAction="#loadRevenueData" prefHeight="45.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 15, 0, 0, 0); -fx-padding: 0 25;" text="DOWNLOAD REPORT" />
                        </HBox>

                        <TextArea fx:id="textAreaRevenue" editable="false" promptText="Nhấn 'DOWNLOAD REPORT' để tải báo cáo tài chính..." style="-fx-font-family: 'Consolas'; -fx-font-size: 15px; -fx-background-color: rgba(0,0,0,0.3); -fx-control-inner-background: rgba(0,0,0,0.3); -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 15; -fx-text-fill: #E0E0E0;" wrapText="true" VBox.vgrow="ALWAYS" />
                    
                    </VBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>