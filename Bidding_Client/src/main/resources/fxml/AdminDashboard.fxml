<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.AdminDashboardController">

    <top>
        <MenuBar style="-fx-font-size: 13px; -fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0; -fx-padding: 4 0 4 0;">
            <Menu text="Dashboard">
                <MenuItem onAction="#refreshData" text="Làm mới" />
            </Menu>
            <Menu text="Quản Lý Người Dùng">
                <MenuItem onAction="#showAllUsers" text="Danh sách người dùng" />
                <MenuItem onAction="#showSearchUser" text="Tìm kiếm người dùng" />
                <MenuItem onAction="#showActivityLog" text="Lịch hoạt động" />
            </Menu>
            <Menu text="Quản Lý Seller">
                <MenuItem onAction="#showApproveSellerDialog" text="Phê duyệt seller" />
            </Menu>
            <Menu text="Phân Tích">
                <MenuItem onAction="#showProductAnalytics" text="Phân tích sản phẩm" />
                <MenuItem onAction="#showRevenueEstimate" text="Ước tính doanh thu" />
            </Menu>
        </MenuBar>
    </top>

    <center>
        <TabPane style="-fx-background-color: transparent; -fx-tab-min-height: 30px; -fx-tab-min-width: 120px;" tabClosingPolicy="UNAVAILABLE">

            <Tab text="Thống Kê Tổng Quan">
                <VBox spacing="20" style="-fx-padding: 20px;">

                    <HBox spacing="20">
                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="TỔNG NGƯỜI DÙNG" />
                            <Label fx:id="lblTotalUsers" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3498DB;" text="0" />
                        </VBox>

                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="TỔNG SẢN PHẨM" />
                            <Label fx:id="lblTotalProducts" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #27AE60;" text="0" />
                        </VBox>

                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="PHIÊN ĐẤU GIÁ" />
                            <Label fx:id="lblTotalAuctions" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;" text="0" />
                        </VBox>

                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="DOANH THU (VND)" />
                            <Label fx:id="lblRevenue" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #F39C12;" text="0" />
                        </VBox>
                    </HBox>

                    <VBox spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" VBox.vgrow="ALWAYS">
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Hoạt Động Gần Đây" />
                        <ListView fx:id="listViewActivities" style="-fx-background-color: transparent; -fx-border-color: #ECF0F1; -fx-border-radius: 4;" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </Tab>

            <Tab text="Quản Lý Người Dùng">
                <VBox spacing="15" style="-fx-padding: 20px; -fx-background-color: #F4F7F6;">

                    <VBox spacing="15" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" VBox.vgrow="ALWAYS">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Danh Sách Tài Khoản" />

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="txtSearchUsername" prefHeight="35.0" promptText="Nhập tên đăng nhập để tìm kiếm..." style="-fx-background-radius: 5; -fx-border-color: #BDC3C7; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleSearchUser" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Tìm Kiếm" />
                        </HBox>

                        <TableView fx:id="tableUsers" style="-fx-border-color: #ECF0F1; -fx-border-radius: 4;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="60" text="ID" style="-fx-alignment: CENTER;"/>
                                <TableColumn prefWidth="150" text="Username" />
                                <TableColumn prefWidth="200" text="Email" />
                                <TableColumn prefWidth="120" text="Vai Trò" style="-fx-alignment: CENTER;"/>
                                <TableColumn prefWidth="120" text="Trạng Thái" style="-fx-alignment: CENTER;"/>
                                <TableColumn prefWidth="150" text="Hành Động" style="-fx-alignment: CENTER;"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>
            </Tab>

            <Tab text="Phân Tích Sản Phẩm">
                <VBox spacing="15" style="-fx-padding: 20px; -fx-background-color: #F4F7F6;">
                    <VBox spacing="15" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Thống Kê Hiệu Suất Sản Phẩm" HBox.hgrow="ALWAYS" />
                            <Button onAction="#loadProductAnalytics" prefHeight="35.0" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Tải Dữ Liệu Mới" />
                        </HBox>
                        <TextArea fx:id="textAreaAnalytics" editable="false" style="-fx-font-family: 'Consolas'; -fx-font-size: 14px; -fx-border-color: #ECF0F1; -fx-border-radius: 4;" wrapText="true" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </Tab>

            <Tab text="Tài Chính">
                <VBox spacing="15" style="-fx-padding: 20px; -fx-background-color: #F4F7F6;">
                    <VBox spacing="15" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Báo Cáo Doanh Thu" HBox.hgrow="ALWAYS" />
                            <Button onAction="#loadRevenueData" prefHeight="35.0" style="-fx-background-color: #F39C12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Tải Báo Cáo" />
                        </HBox>
                        <TextArea fx:id="textAreaRevenue" editable="false" style="-fx-font-family: 'Consolas'; -fx-font-size: 14px; -fx-border-color: #ECF0F1; -fx-border-radius: 4;" wrapText="true" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>