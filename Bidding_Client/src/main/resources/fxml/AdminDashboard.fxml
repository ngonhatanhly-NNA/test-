<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #E8EEF2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: linear-gradient(to right, #0F172A, #1E293B); -fx-padding: 0 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 4);">
            <children>
                <VBox alignment="CENTER_LEFT">
                    <Label text="ADMIN PORTAL" textFill="#D4AF37" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="System management and global analytics" textFill="#94A3B8" style="-fx-font-size: 13px; -fx-font-style: italic;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#showApproveSellerDialog" text="✅ APPROVE SELLERS" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #F59E0B, #FDE047); -fx-text-fill: #451A03; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button onAction="#refreshData" text="🔄 Refresh System" prefHeight="40.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-text-fill: #F8FAFC; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </children>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <Tab text="Overview">
                <VBox spacing="25" style="-fx-padding: 30px;">
                    <HBox spacing="25">
                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-padding: 25px; -fx-background-radius: 16;" HBox.hgrow="ALWAYS">
                            <Label text="👥 TOTAL USERS" />
                            <Label fx:id="lblTotalUsers" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-padding: 25px; -fx-background-radius: 16;" HBox.hgrow="ALWAYS">
                            <Label text="📦 TOTAL ITEMS" />
                            <Label fx:id="lblTotalProducts" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #10B981;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-padding: 25px; -fx-background-radius: 16;" HBox.hgrow="ALWAYS">
                            <Label text="🔨 AUCTIONS" />
                            <Label fx:id="lblTotalAuctions" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #EF4444;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-padding: 25px; -fx-background-radius: 16;" HBox.hgrow="ALWAYS">
                            <Label text="💰 TOTAL REVENUE (VNĐ)" />
                            <Label fx:id="lblRevenue" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;" text="0" />
                        </VBox>
                    </HBox>
                    <ListView fx:id="listViewActivities" VBox.vgrow="ALWAYS" />
                </VBox>
            </Tab>

            <Tab fx:id="userManagementTab" text="User Management">
                <VBox spacing="20" style="-fx-padding: 30px;">
                    <VBox spacing="20" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 25, 0, 5, 5);" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="System Accounts" HBox.hgrow="ALWAYS" />
                            <Button onAction="#showAllUsers" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #3B82F6; -fx-border-color: #3B82F6; -fx-border-radius: 8; -fx-cursor: hand;" text="Reload All Users">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Button>
                            <TextField fx:id="txtSearchUsername" prefHeight="45.0" prefWidth="320.0" promptText="🔍 Search user by name..." style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-font-size: 14px; -fx-padding: 0 15; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.04), 5, 0, 0, 2);" />
                            <Button onAction="#handleSearchUser" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(30,41,59,0.3), 10, 0, 0, 3);" text="SEARCH">
                                <font><Font name="System ExtraBold" size="14.0" /></font>
                            </Button>
                        </HBox>
                        <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" text="ID" />
                                <TableColumn fx:id="colUsername" text="Username" />
                                <TableColumn fx:id="colEmail" text="Email" />
                                <TableColumn fx:id="colRole" text="Role" />
                                <TableColumn fx:id="colStatus" text="Status" />
                                <TableColumn fx:id="colShopName" text="Shop Name" />
                                <TableColumn fx:id="colRating" text="Rating" />
                                <TableColumn fx:id="colVerified" text="Verified" />
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </Tab>

            <Tab fx:id="itemAnalysisTab" text="Item Analysis">
                <VBox spacing="20" style="-fx-padding: 30px;">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="📊 Product Performance Analytics" HBox.hgrow="ALWAYS" />
                        <Button onAction="#loadProductAnalytics" text="GENERATE REPORT" prefHeight="45.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </HBox>
                    <TableView fx:id="tableItems" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colItemId" text="ID" />
                            <TableColumn fx:id="colItemName" text="Name" />
                            <TableColumn fx:id="colItemDescription" text="Description" />
                            <TableColumn fx:id="colItemStartingPrice" text="Starting Price" />
                            <TableColumn fx:id="colItemStatus" text="Status" />
                            <TableColumn fx:id="colItemAction" text="Action" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab fx:id="financialReportTab" text="Financial Report">
                <VBox spacing="20" style="-fx-padding: 30px;">
                    <HBox>
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="💰 System Revenue Report" HBox.hgrow="ALWAYS" />
                        <Button onAction="#loadRevenueData" text="DOWNLOAD REPORT" prefHeight="45.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FDE047); -fx-text-fill: #451A03; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </HBox>
                    <TextArea fx:id="textAreaRevenue" editable="false" wrapText="true" VBox.vgrow="ALWAYS" />
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
