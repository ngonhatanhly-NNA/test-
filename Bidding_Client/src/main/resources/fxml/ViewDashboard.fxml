<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="950.0" spacing="25.0" style="-fx-background-color: #121212; -fx-padding: 35 40;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.ViewDashboardController">
    <children>

        <HBox alignment="CENTER_LEFT">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Explore Auctions" textFill="#F5F5F5">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                            <style>
                                -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.3), 10, 0, 0, 0);
                            </style>
                        </Label>
                        <Label text="Check out the latest items from our sellers" textFill="#A0A0A0">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <ComboBox prefWidth="160.0" promptText="Sort by: Newest" style="-fx-background-color: #242424; -fx-border-color: rgba(212,175,55,0.3); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #E0E0E0; -fx-prompt-text-fill: #A0A0A0; -fx-cursor: hand;" />
            </children>
        </HBox>

        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #121212; -fx-border-color: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
            <content>

                <FlowPane fx:id="itemContainer" hgap="30.0" vgap="30.0" style="-fx-background-color: transparent; -fx-padding: 10 5 20 5;">
                    <children>

                        <VBox alignment="CENTER" prefWidth="240.0" spacing="15.0" style="-fx-background-color: #181818; -fx-border-color: rgba(212,175,55,0.3); -fx-border-width: 1.5; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 20, 0, 0, 8);">
                            <children>
                                
                                <StackPane style="-fx-background-color: #242424; -fx-background-radius: 12; -fx-padding: 15;">
                                    <ImageView fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                            <Image url="@../images/ABRA.png" />
                                        </image>
                                        <style>
                                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 5);
                                        </style>
                                    </ImageView>
                                </StackPane>

                                <VBox alignment="CENTER" spacing="5.0">
                                    <Label text="Rare Pixel Abra" textFill="#E0E0E0">
                                        <font>
                                            <Font name="System Bold" size="18.0" />
                                        </font>
                                    </Label>
                                    <Label text="Highest Bid: $150" textFill="#D4AF37">
                                        <font>
                                            <Font name="System Bold" size="15.0" />
                                        </font>
                                        <style>
                                            -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 8, 0, 0, 0);
                                        </style>
                                    </Label>
                                </VBox>

                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 10, 0, 0, 0);" text="Place Bid" />
                            </children>
                        </VBox>


                        <VBox alignment="CENTER" prefWidth="240.0" spacing="15.0" style="-fx-background-color: #181818; -fx-border-color: rgba(212,175,55,0.3); -fx-border-width: 1.5; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 20, 0, 0, 8);">
                            <children>
                                <StackPane style="-fx-background-color: #242424; -fx-background-radius: 12; -fx-padding: 15;">
                                    <ImageView fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                            <Image url="@../images/ABSOL.png" />
                                        </image>
                                        <style>
                                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 5);
                                        </style>
                                    </ImageView>
                                </StackPane>
                                <VBox alignment="CENTER" spacing="5.0">
                                    <Label text="Dark Absol" textFill="#E0E0E0">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Label>
                                    <Label text="Highest Bid: $320" textFill="#D4AF37">
                                        <font><Font name="System Bold" size="15.0" /></font>
                                        <style>-fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 8, 0, 0, 0);</style>
                                    </Label>
                                </VBox>
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 10, 0, 0, 0);" text="Place Bid" />
                            </children>
                        </VBox>


                        <VBox alignment="CENTER" prefWidth="240.0" spacing="15.0" style="-fx-background-color: #181818; -fx-border-color: rgba(212,175,55,0.3); -fx-border-width: 1.5; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 20, 0, 0, 8);">
                            <children>
                                <StackPane style="-fx-background-color: #242424; -fx-background-radius: 12; -fx-padding: 15;">
                                    <ImageView fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                            <Image url="@../images/Pikachu.png" />
                                        </image>
                                        <style>
                                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 5);
                                        </style>
                                    </ImageView>
                                </StackPane>
                                <VBox alignment="CENTER" spacing="5.0">
                                    <Label text="Classic Pikachu" textFill="#E0E0E0">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Label>
                                    <Label text="Highest Bid: $500" textFill="#D4AF37">
                                        <font><Font name="System Bold" size="15.0" /></font>
                                        <style>-fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 8, 0, 0, 0);</style>
                                    </Label>
                                </VBox>
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 10, 0, 0, 0);" text="Place Bid" />
                            </children>
                        </VBox>

                    </children>
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
</VBox>