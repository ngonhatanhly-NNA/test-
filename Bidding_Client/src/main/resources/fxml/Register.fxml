<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.auth.RegisterController">
    <children>
        <VBox prefHeight="720.0" prefWidth="550.0" style="-fx-background-color: linear-gradient(to bottom right, #0F172A, #1E293B); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 5, 0, 0);">
            <children>
                <ImageView fitHeight="720.0" fitWidth="550.0" pickOnBounds="true" preserveRatio="false">
                    <image>
                        <Image url="@../images/GavelImg.png" />
                    </image>
                </ImageView>
            </children>
        </VBox>

        <StackPane style="-fx-background-color: #E8EEF2;" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" prefWidth="540.0" spacing="18.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.1), 40, 0, 0, 15);">
                    <padding>
                        <Insets bottom="40.0" left="45.0" right="45.0" top="40.0" />
                    </padding>
                    <children>
                        
                        <VBox alignment="CENTER" spacing="5.0">
                            <Label text="CREATE ACCOUNT" textFill="#0F172A">
                                <font>
                                    <Font name="System Bold" size="30.0" />
                                </font>
                                <style>
                                    -fx-letter-spacing: 1px;
                                </style>
                            </Label>
                            <Label text="Join us to start bidding and selling assets" textFill="#64748B">
                                <font>
                                    <Font size="14.0" />
                                </font>
                                <VBox.margin>
                                    <Insets bottom="5.0" />
                                </VBox.margin>
                            </Label>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label fx:id="lblMessage" textFill="#DC2626">
                                <font>
                                    <Font name="System Bold" size="13.0" />
                                </font>
                            </Label>
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label text="Username (*)" textFill="#475569">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <TextField fx:id="txtUsername" prefHeight="45.0" promptText="Choose a username" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.04), 5, 0, 0, 2);" />
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label text="Full Name (*)" textFill="#475569">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <TextField fx:id="txtFullName" prefHeight="45.0" promptText="Enter your full name" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.04), 5, 0, 0, 2);" />
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="8.0">
                            <Label text="Email Address (*)" textFill="#475569">
                                <font><Font name="System Bold" size="13.0" /></font>
                            </Label>
                            <TextField fx:id="txtEmail" prefHeight="45.0" promptText="Enter your email address" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.04), 5, 0, 0, 2);" />
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label text="Password (*)" textFill="#475569">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <PasswordField fx:id="txtPassword" prefHeight="45.0" promptText="Create password" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.04), 5, 0, 0, 2);" />
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label text="Confirm Password (*)" textFill="#475569">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <PasswordField fx:id="txtConfirmPassword" prefHeight="45.0" promptText="Repeat password" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-padding: 0 15; -fx-font-size: 14px; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.04), 5, 0, 0, 2);" />
                                </VBox>
                            </children>
                        </HBox>

                        <Button fx:id="btnRegister" maxWidth="1.7976931348623157E308" onAction="#handleRegister" prefHeight="50.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FDE047); -fx-background-radius: 10; -fx-text-fill: #451A03; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 18, 0, 0, 5);" text="REGISTER NOW">
                            <font>
                                <Font name="System ExtraBold" size="16.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>

                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Already have an account?" textFill="#64748B">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                                <Button onAction="#switchLogin" style="-fx-background-color: transparent; -fx-text-fill: #B8860B; -fx-cursor: hand; -fx-underline: true;" text="Sign in here">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </VBox>
                        
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</HBox>