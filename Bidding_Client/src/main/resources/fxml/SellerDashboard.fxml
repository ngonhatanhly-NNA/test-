<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.SellerDashboardController">

    <top>
        <MenuBar style="-fx-font-size: 14px; -fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 2 0; -fx-padding: 6 10 6 10; -fx-cursor: hand;">
            <Menu text="System Management">
                <MenuItem onAction="#refreshData" text="Refresh" />
                <SeparatorMenuItem />
                <MenuItem onAction="#logout" text="Log out" />
            </Menu>
            <Menu text="Inventory Management">
                <MenuItem onAction="#showAllItems" text="Item storage" />
                <MenuItem onAction="#createNewItem" text="Create new item" />
            </Menu>
            <Menu text="Business Analytics">
                <MenuItem onAction="#showStatistics" text="Selling data" />
            </Menu>
            <Menu text="Auction Monitoring">
                <MenuItem onAction="#loadLiveAuctions" text="View active auction" />
            </Menu>
        </MenuBar>
    </top>

    <center>
        <TabPane style="-fx-background-color: transparent; -fx-tab-min-height: 35px; -fx-tab-min-width: 140px; -fx-font-weight: bold; -fx-font-size: 13px;" tabClosingPolicy="UNAVAILABLE">

            <Tab text="Overview">
                <VBox spacing="25" style="-fx-padding: 30px;">
                    <HBox spacing="30">
                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 30px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #95A5A6; -fx-font-weight: bold; -fx-tracking: 1px;" text="⭐ UY TÍN CỬA HÀNG" />
                            <Label fx:id="lblRating" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #F1C40F;" text="5.0" />
                        </VBox>

                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 30px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #95A5A6; -fx-font-weight: bold; -fx-tracking: 1px;" text="📦 TỔNG SẢN PHẨM" />
                            <Label fx:id="lblTotalItems" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #3498DB;" text="0" />
                        </VBox>
                    </HBox>

                    <VBox spacing="15" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Hoạt Động Gần Đây" />
                        </HBox>
                        <ListView fx:id="listViewActivities" style="-fx-background-color: transparent; -fx-border-color: #F1F2F6; -fx-border-radius: 8; -fx-font-size: 14px;" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </Tab>

            <Tab text="Item Management">
                <VBox spacing="20" style="-fx-padding: 30px;">
                    <VBox spacing="20" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Kho Hàng Của Bạn" HBox.hgrow="ALWAYS" />
                            <TextField fx:id="txtSearchItem" prefHeight="40.0" prefWidth="300.0" promptText="🔍 Nhập tên sản phẩm cần tìm..." style="-fx-background-radius: 8; -fx-border-color: #DFE6E9; -fx-border-radius: 8; -fx-font-size: 14px;" />
                            <Button onAction="#handleSearchItem" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="TÌM KIẾM" />
                        </HBox>

                        <TableView fx:id="tableItems" style="-fx-border-color: #F1F2F6; -fx-border-radius: 8; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="70" text="Mã SP" style="-fx-alignment: CENTER;" />
                                <TableColumn prefWidth="300" text="Tên Sản Phẩm" />
                                <TableColumn prefWidth="150" text="Giá Khởi Điểm" style="-fx-alignment: CENTER_RIGHT;" />
                                <TableColumn prefWidth="150" text="Danh Mục" style="-fx-alignment: CENTER;" />
                                <TableColumn prefWidth="150" text="Trạng Thái" style="-fx-alignment: CENTER;" />
                                <TableColumn prefWidth="180" text="Hành Động" style="-fx-alignment: CENTER;" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>
            </Tab>

            <Tab text="Selling Analysis">
                <VBox spacing="20" style="-fx-padding: 30px;">
                    <VBox spacing="20" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="📈 Thống Kê Hiệu Suất" HBox.hgrow="ALWAYS" />
                            <Button onAction="#loadStatistics" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="LÀM MỚI BÁO CÁO" />
                        </HBox>
                        <TextArea fx:id="textAreaStatistics" editable="false" style="-fx-font-family: 'Consolas'; -fx-font-size: 15px; -fx-border-color: #F1F2F6; -fx-border-radius: 8; -fx-background-color: #FAFAFA;" wrapText="true" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </Tab>

            <Tab text="View Current Active Action">
                <HBox spacing="25" style="-fx-padding: 30px;">

                    <VBox spacing="15" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" HBox.hgrow="ALWAYS" prefWidth="450">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="🔴 Phiên Đang Chạy" HBox.hgrow="ALWAYS" />
                            <Button onAction="#loadLiveAuctions" prefHeight="35.0" style="-fx-background-color: #ECF0F1; -fx-text-fill: #2C3E50; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;" text="Tải Lại" />
                        </HBox>
                        <ListView fx:id="listViewAuctions" style="-fx-font-size: 14px; -fx-background-color: transparent; -fx-border-color: #F1F2F6; -fx-border-radius: 8;" VBox.vgrow="ALWAYS" />
                    </VBox>

                    <VBox spacing="20" HBox.hgrow="ALWAYS" prefWidth="650">

                        <VBox spacing="30" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 35px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50; -fx-border-color: #F1F2F6; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 15 0;" text="Chi Tiết Màn Rượt Đuổi Giá" maxWidth="Infinity"/>

                            <VBox spacing="20" style="-fx-padding: 10 0 10 0;">
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label prefWidth="200" text="Name:" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;" />
                                    <Label fx:id="lblAuctionItemName" text="---" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label prefWidth="200" text="Leading Person:" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;" />
                                    <Label fx:id="lblLeadingBidder" text="---" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2980B9;" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label prefWidth="200" text="Time Remaining:" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;" />
                                    <Label fx:id="lblTimeRemaining" text="---" style="-fx-font-size: 18px; -fx-text-fill: #E67E22; -fx-font-weight: bold;" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label prefWidth="200" text="Bid Step:" style="-fx-font-size: 16px; -fx-text-fill: #7F8C8D;" />
                                    <Label fx:id="lblBidStep" text="---" style="-fx-font-size: 16px; -fx-text-fill: #2C3E50;" />
                                </HBox>
                            </VBox>

                            <VBox alignment="CENTER" spacing="12" style="-fx-background-color: #FFF0F0; -fx-border-color: #FF7675; -fx-border-width: 2; -fx-border-radius: 12; -fx-padding: 40px;">
                                <Label text="Highest Current: " style="-fx-font-size: 16px; -fx-text-fill: #D63031; -fx-font-weight: bold; -fx-tracking: 2px;" />
                                <Label fx:id="lblCurrentAuctionPrice" text="0 VND" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #D63031;" />
                            </VBox>
                        </VBox>

                    </VBox>
                </HBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>