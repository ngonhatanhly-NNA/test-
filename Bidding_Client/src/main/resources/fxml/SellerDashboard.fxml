<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.SellerDashboardController">

    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-padding: 10 30 10 30;">
            <children>
                <Button onAction="#createNewItem" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 12, 0, 0, 0); -fx-padding: 0 20;" text="➕ ADD NEW ITEM">
                    <font><Font name="System ExtraBold" size="13.0" /></font>
                </Button>
                <Button onAction="#refreshData" prefHeight="40.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #E0E0E0; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 20;" text="🔄 Refresh">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </HBox>
    </top>

    <center>
        <TabPane style="-fx-background-color: transparent; -fx-tab-min-height: 40px; -fx-tab-min-width: 160px; -fx-font-weight: bold; -fx-font-size: 14px;" stylesheets="@tabstyle.css" tabClosingPolicy="UNAVAILABLE">

            <Tab text="Overview">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="25" style="-fx-padding: 30px;">
                            
                            <HBox spacing="30">
                                <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 35px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 14px; -fx-text-fill: #A0A0A0; -fx-font-weight: bold;" text="⭐ STORE RATING" />
                                    <Label fx:id="lblRating" style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.5), 15, 0, 0, 0);" text="0.0 ★">
                                        <textFill>
                                            <LinearGradient endX="1.0" endY="1.0">
                                                <stops>
                                                    <Stop color="#FFD700" />
                                                    <Stop color="#D4AF37" offset="1.0" />
                                                </stops>
                                            </LinearGradient>
                                        </textFill>
                                    </Label>
                                </VBox>

                                <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 35px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 14px; -fx-text-fill: #A0A0A0; -fx-font-weight: bold;" text="📦 TOTAL INVENTORY" />
                                    <Label fx:id="lblTotalItems" style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #34D399; -fx-effect: dropshadow(gaussian, rgba(52,211,153,0.4), 15, 0, 0, 0);" text="0" />
                                </VBox>
                            </HBox>

                            <VBox minHeight="400.0" spacing="15" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">
                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #F5F5F5;" text="Recent Activities" />
                                <ListView fx:id="listViewActivities" style="-fx-background-color: rgba(0,0,0,0.2); -fx-control-inner-background: rgba(0,0,0,0.2); -fx-border-color: rgba(212,175,55,0.1); -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS" />
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Item Management">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="20" style="-fx-padding: 30px;">
                            <VBox spacing="20" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">

                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="Your Inventory" HBox.hgrow="ALWAYS" />

                                    <Button onAction="#showAllItems" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-cursor: hand;" text="Reload All Items">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Button>

                                    <TextField fx:id="txtSearchItem" prefHeight="40.0" prefWidth="320.0" promptText="🔍 Search item by name..." style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B; -fx-background-radius: 8; -fx-border-color: rgba(212,175,55,0.3); -fx-border-radius: 8; -fx-font-size: 14px; -fx-padding: 0 15; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.6), 5, 0, 0, 2);" />
                                    
                                    <Button onAction="#handleSearchItem" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #242424; -fx-text-fill: #D4AF37; -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 0);" text="SEARCH">
                                        <font><Font name="System ExtraBold" size="13.0" /></font>
                                    </Button>
                                </HBox>

                                <TableView fx:id="tableItems" minHeight="500.0" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colItemId" prefWidth="90" style="-fx-alignment: CENTER;" text="Item ID" />
                                        <TableColumn fx:id="colItemName" prefWidth="300" text="Item Name" />
                                        <TableColumn fx:id="colStartingPrice" prefWidth="160" style="-fx-alignment: CENTER_RIGHT;" text="Starting Price" />
                                        <TableColumn fx:id="colCategory" prefWidth="150" style="-fx-alignment: CENTER;" text="Category" />
                                        <TableColumn fx:id="colStatus" prefWidth="150" style="-fx-alignment: CENTER;" text="Status" />
                                        <TableColumn fx:id="colAction" prefWidth="180" style="-fx-alignment: CENTER;" text="Action" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Selling Analysis">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="20" style="-fx-padding: 30px;">
                            <VBox minHeight="500.0" spacing="20" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="📈 Performance Analytics" HBox.hgrow="ALWAYS" />
                                    
                                    <Button onAction="#loadStatistics" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: rgba(16, 185, 129, 0.2); -fx-text-fill: #34D399; -fx-border-color: #10B981; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="GENERATE REPORT">
                                        <font><Font name="System ExtraBold" size="13.0" /></font>
                                    </Button>
                                </HBox>
                                <TextArea fx:id="textAreaStatistics" editable="false" promptText="Nhấn 'GENERATE REPORT' để tải báo cáo..." style="-fx-font-family: 'Consolas'; -fx-font-size: 15px; -fx-background-color: rgba(0,0,0,0.3); -fx-control-inner-background: rgba(0,0,0,0.3); -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10; -fx-text-fill: #E0E0E0;" wrapText="true" VBox.vgrow="ALWAYS" />
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Live Auction Monitoring">
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <HBox minHeight="600.0" spacing="30" style="-fx-padding: 30px;">
                            
                            <VBox prefWidth="450" spacing="15" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="🔴 Active Sessions" HBox.hgrow="ALWAYS" />
                                    <Button onAction="#loadLiveAuctions" prefHeight="35.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: #E0E0E0; -fx-border-color: rgba(212,175,55,0.4); -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Reload">
                                        <font><Font name="System Bold" size="12.0" /></font>
                                    </Button>
                                </HBox>
                                <ListView fx:id="listViewAuctions" style="-fx-font-size: 15px; -fx-background-color: rgba(0,0,0,0.2); -fx-control-inner-background: rgba(0,0,0,0.2); -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS" />
                            </VBox>

                            <VBox prefWidth="650" spacing="20" HBox.hgrow="ALWAYS">
                                <VBox spacing="30" style="-fx-background-color: #181818; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16; -fx-padding: 35px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 5, 5);" VBox.vgrow="ALWAYS">

                                    <Label maxWidth="Infinity" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #F5F5F5; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;" text="Live Bidding Details" />

                                    <VBox spacing="20" style="-fx-padding: 10 0 10 0;">
                                        <HBox alignment="CENTER_LEFT" spacing="15">
                                            <Label prefWidth="180" style="-fx-font-size: 16px; -fx-text-fill: #A0A0A0;" text="Item Name:" />
                                            <Label fx:id="lblAuctionItemName" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #D4AF37;" text="---" />
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="15">
                                            <Label prefWidth="180" style="-fx-font-size: 16px; -fx-text-fill: #A0A0A0;" text="Leading Bidder:" />
                                            <Label fx:id="lblLeadingBidder" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;" text="---" />
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="15">
                                            <Label prefWidth="180" style="-fx-font-size: 16px; -fx-text-fill: #A0A0A0;" text="Time Remaining:" />
                                            <Label fx:id="lblTimeRemaining" style="-fx-font-size: 20px; -fx-text-fill: #EF4444; -fx-font-weight: bold;" text="---" />
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="15">
                                            <Label prefWidth="180" style="-fx-font-size: 16px; -fx-text-fill: #A0A0A0;" text="Minimum Bid Step:" />
                                            <Label fx:id="lblBidStep" style="-fx-font-size: 18px; -fx-text-fill: #E0E0E0;" text="---" />
                                        </HBox>
                                    </VBox>

                                    <VBox alignment="CENTER" spacing="12" style="-fx-background-color: rgba(24,24,24,0.8); -fx-border-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-border-width: 2; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 40px; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.15), 25, 0, 0, 0);">
                                        <Label style="-fx-font-size: 16px; -fx-text-fill: #A0A0A0; -fx-font-weight: bold; -fx-letter-spacing: 1.5px;" text="HIGHEST CURRENT BID" />
                                        <Label fx:id="lblCurrentAuctionPrice" style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.4), 10, 0, 0, 0);" text="0 VNĐ" />
                                    </VBox>

                                </VBox>
                            </VBox>
                        </HBox>
                    </content>
                </ScrollPane>
            </Tab>

        </TabPane>
    </center>
</BorderPane>