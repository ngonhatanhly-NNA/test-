<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox stylesheets="@calendar.css" prefWidth="500.0" spacing="25.0" style="-fx-background-color: #181818; -fx-padding: 35 40; -fx-border-color: rgba(212,175,55,0.4); -fx-border-width: 2; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 30, 0, 0, 10);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.client.controller.dashboard.CreateAuctionController">
    <children>

        <VBox spacing="5.0">
            <Label text="🔨 OPEN LIVE AUCTION" textFill="#D4AF37">
                <font><Font name="System Bold" size="24.0" /></font>
                <style>
                    -fx-letter-spacing: 1.5px;
                    -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 8, 0, 0, 0);
                </style>
            </Label>
            <Label text="Set the schedule and minimum step price for this asset." textFill="#A0A0A0">
                <font><Font name="System Italic" size="14.0" /></font>
            </Label>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Start Time" textFill="#E0E0E0">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <HBox spacing="15.0">
                <DatePicker fx:id="dpStartDate" prefHeight="45.0" promptText="Select Date" styleClass="dark-date-picker" HBox.hgrow="ALWAYS" style="-fx-font-size: 14px; -fx-background-color: #242424; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8;" />
                
                <TextField fx:id="txtStartTime" prefHeight="45.0" prefWidth="110.0" promptText="HH:mm" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-alignment: center; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" />
            </HBox>
        </VBox>

        <VBox spacing="8.0">
            <Label text="End Time" textFill="#E0E0E0">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <HBox spacing="15.0">
                <DatePicker fx:id="dpEndDate" prefHeight="45.0" promptText="Select Date" styleClass="dark-date-picker" HBox.hgrow="ALWAYS" style="-fx-font-size: 14px; -fx-background-color: #242424; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8;" />
                
                <TextField fx:id="txtEndTime" prefHeight="45.0" prefWidth="110.0" promptText="HH:mm" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-alignment: center; -fx-text-fill: #F5F5F5; -fx-prompt-text-fill: #64748B;" />
            </HBox>
        </VBox>

        <VBox spacing="8.0" style="-fx-padding: 5 0 0 0;">
            <Label text="Minimum Step Price (VNĐ)" textFill="#E0E0E0">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <TextField fx:id="txtStepPrice" prefHeight="45.0" promptText="VD: 50000" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: rgba(0,0,0,0.3); -fx-border-color: rgba(212,175,55,0.5); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15; -fx-text-fill: #34D399; -fx-prompt-text-fill: #64748B; -fx-effect: innershadow(gaussian, rgba(0,0,0,0.6), 5, 0, 0, 2);" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <VBox.margin><Insets top="15.0" /></VBox.margin>
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="45.0" prefWidth="110.0" style="-fx-background-color: transparent; -fx-border-color: rgba(239,68,68,0.6); -fx-border-width: 1.5; -fx-border-radius: 8; -fx-text-fill: #EF4444; -fx-cursor: hand;" text="Cancel">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                
                <Button mnemonicParsing="false" onAction="#handleStartAuction" prefHeight="45.0" prefWidth="170.0" style="-fx-background-color: linear-gradient(to right, #D4AF37, #FFD700); -fx-text-fill: #121212; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(212,175,55,0.4), 15, 0, 0, 0);" text="Start Auction">
                    <font><Font name="System ExtraBold" size="14.0" /></font>
                </Button>
            </children>
        </HBox>

    </children>
</VBox>